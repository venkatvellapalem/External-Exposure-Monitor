{
    "title": "EASM SOC Command Center",
    "description": "External Attack Surface Monitor (Dashboard Studio)",
    "theme": "dark",
    "visualizations": {
        "viz_total_exposures": {
            "type": "splunk.singlevalue",
            "dataSources": {
                "primary": "ds_total_exposures"
            },
            "title": "Active Exposures",
            "options": {
                "majorColor": "> majorColorEditorConfig"
            },
            "context": {
                "majorColorEditorConfig": [
                    {"value": "#53a051", "match": [0, 10]},
                    {"value": "#f8be34", "match": [10, 50]},
                    {"value": "#dc4e41", "match": [50, 1000]}
                ]
            },
            "eventHandlers": [
                {
                    "type": "drilldown.customUrl",
                    "options": {
                        "url": "/app/search/search?q=search%20index%3D*%20source%3Deasm_collector%20%7C%20dedup%20ip%20port%20%7C%20search%20status%3D%22open%22%20%7C%20eval%20domain%20%3D%20coalesce(nullif(domain%2C%20%22%22)%2C%20%22N%2FA%22)%20%7C%20eval%20hostname%20%3D%20coalesce(mvindex('hostnames%7B%7D'%2C%200)%2C%20%22N%2FA%22)%20%7C%20table%20_time%2C%20ip%2C%20domain%2C%20hostname%2C%20port%2C%20risk%2C%20status&earliest=$global_time.earliest$&latest=$global_time.latest$",
                        "newTab": true
                    }
                }
            ]
        },
        "viz_critical_exposures": {
            "type": "splunk.singlevalue",
            "dataSources": {
                "primary": "ds_critical_exposures"
            },
            "title": "Critical / High Threat Alerts",
            "options": {
                "majorColor": "#dc4e41"
            },
            "eventHandlers": [
                {
                    "type": "drilldown.customUrl",
                    "options": {
                        "url": "/app/search/search?q=search%20index%3D*%20source%3Deasm_collector%20(risk%3D%22Critical%22%20OR%20risk%3D%22High%22)%20%7C%20dedup%20ip%20port%20%7C%20search%20status%3D%22open%22%20%7C%20eval%20domain%20%3D%20coalesce(nullif(domain%2C%20%22%22)%2C%20%22N%2FA%22)%20%7C%20eval%20hostname%20%3D%20coalesce(mvindex('hostnames%7B%7D'%2C%200)%2C%20%22N%2FA%22)%20%7C%20table%20_time%2C%20ip%2C%20domain%2C%20hostname%2C%20port%2C%20risk%2C%20status%2C%20leaks%2C%20vulns%7B%7D&earliest=$global_time.earliest$&latest=$global_time.latest$",
                        "newTab": true
                    }
                }
            ]
        },
        "viz_ingest_rate": {
            "type": "splunk.line",
            "dataSources": {
                "primary": "ds_ingest_rate"
            },
            "title": "Ingestion Scan Rate over Time"
        },
        "viz_risk_breakdown": {
            "type": "splunk.pie",
            "dataSources": {
                "primary": "ds_risk_breakdown"
            },
            "title": "Attack Surface Risk Severity",
            "options": {
                "seriesColorsByField": {
                    "Low": "#53a051",
                    "Medium": "#f8be34",
                    "High": "#f1813f",
                    "Critical": "#dc4e41"
                }
            },
            "eventHandlers": [
                {
                    "type": "drilldown.customUrl",
                    "options": {
                        "url": "/app/search/search?q=search%20index%3D*%20source%3Deasm_collector%20risk%3D%22$row.risk.value$%22%20%7C%20dedup%20ip%20port%20%7C%20search%20status%3D%22open%22%20%7C%20eval%20domain%20%3D%20coalesce(nullif(domain%2C%20%22%22)%2C%20%22N%2FA%22)%20%7C%20eval%20hostname%20%3D%20coalesce(mvindex('hostnames%7B%7D'%2C%200)%2C%20%22N%2FA%22)%20%7C%20table%20_time%2C%20ip%2C%20domain%2C%20hostname%2C%20port%2C%20risk%2C%20status&earliest=$global_time.earliest$&latest=$global_time.latest$",
                        "newTab": true
                    }
                }
            ]
        },
        "viz_top_ports": {
            "type": "splunk.bar",
            "dataSources": {
                "primary": "ds_top_ports"
            },
            "title": "Exposed Ports Distribution by Risk",
            "options": {
                "stackMode": "stacked",
                "seriesColorsByField": {
                    "Low": "#53a051",
                    "Medium": "#f8be34",
                    "High": "#f1813f",
                    "Critical": "#dc4e41"
                }
            },
            "eventHandlers": [
                {
                    "type": "drilldown.customUrl",
                    "options": {
                        "url": "/app/search/search?q=search%20index%3D*%20source%3Deasm_collector%20port%3D$row.port.value$%20%7C%20dedup%20ip%20port%20%7C%20search%20status%3D%22open%22%20%7C%20eval%20domain%20%3D%20coalesce(nullif(domain%2C%20%22%22)%2C%20%22N%2FA%22)%20%7C%20eval%20hostname%20%3D%20coalesce(mvindex('hostnames%7B%7D'%2C%200)%2C%20%22N%2FA%22)%20%7C%20table%20_time%2C%20ip%2C%20domain%2C%20hostname%2C%20port%2C%20risk%2C%20status&earliest=$global_time.earliest$&latest=$global_time.latest$",
                        "newTab": true
                    }
                }
            ]
        },
        "viz_map": {
            "type": "splunk.map",
            "dataSources": {
                "primary": "ds_map"
            },
            "title": "Geographical Exposure Map",
            "options": {
                "center": [20, 0],
                "zoom": 1
            }
        },
        "viz_recent_exposures": {
            "type": "splunk.table",
            "dataSources": {
                "primary": "ds_recent_exposures"
            },
            "title": "Live EASM Alert Feed (Real-Time Splunk Ingestion)",
            "eventHandlers": [
                {
                    "type": "drilldown.customUrl",
                    "options": {
                        "url": "/app/search/search?q=search%20index%3D*%20source%3Deasm_collector%20ip%3D%22$row.ip.value$%22%20port%3D$row.port.value$",
                        "newTab": true
                    }
                }
            ]
        }
    },
    "dataSources": {
        "ds_total_exposures": {
            "type": "ds.search",
            "options": {
                "query": "index=* source=easm_collector | dedup ip port | search status=\"open\" | stats count"
            }
        },
        "ds_critical_exposures": {
            "type": "ds.search",
            "options": {
                "query": "index=* source=easm_collector (risk=\"Critical\" OR risk=\"High\") | dedup ip port | search status=\"open\" | stats count"
            }
        },
        "ds_ingest_rate": {
            "type": "ds.search",
            "options": {
                "query": "index=* source=easm_collector | timechart span=1h count by status"
            }
        },
        "ds_risk_breakdown": {
            "type": "ds.search",
            "options": {
                "query": "index=* source=easm_collector | dedup ip port | search status=\"open\" | stats count by risk"
            }
        },
        "ds_top_ports": {
            "type": "ds.search",
            "options": {
                "query": "index=* source=easm_collector | dedup ip port | search status=\"open\" | chart count by port, risk"
            }
        },
        "ds_map": {
            "type": "ds.search",
            "options": {
                "query": "index=* source=easm_collector | dedup ip port | search status=\"open\" | iplocation ip | geostats count"
            }
        },
        "ds_recent_exposures": {
            "type": "ds.search",
            "options": {
                "query": "index=* source=easm_collector | eval domain = coalesce(nullif(domain, \"\"), \"N/A\") | eval hostname = coalesce(mvindex('hostnames{}', 0), \"N/A\") | table _time, ip, domain, hostname, port, risk, status | sort - _time"
            }
        }
    },
    "defaults": {
        "dataSources": {
            "ds.search": {
                "options": {
                    "queryParameters": {
                        "latest": "$global_time.latest$",
                        "earliest": "$global_time.earliest$"
                    }
                }
            }
        }
    },
    "inputs": {
        "input_global_trp": {
            "type": "input.timerange",
            "options": {
                "token": "global_time",
                "defaultValue": "-24h@h,now"
            },
            "title": "Global Time Range"
        }
    },
    "layout": {
        "type": "absolute",
        "options": {
            "display": "auto-scale",
            "backgroundColor": "#0c0f12",
            "width": 1600,
            "height": 1100
        },
        "structure": [
            {
                "item": "viz_total_exposures",
                "type": "block",
                "position": {"x": 20, "y": 80, "w": 300, "h": 180}
            },
            {
                "item": "viz_critical_exposures",
                "type": "block",
                "position": {"x": 340, "y": 80, "w": 300, "h": 180}
            },
            {
                "item": "viz_ingest_rate",
                "type": "block",
                "position": {"x": 660, "y": 80, "w": 920, "h": 180}
            },
            {
                "item": "viz_risk_breakdown",
                "type": "block",
                "position": {"x": 20, "y": 280, "w": 500, "h": 380}
            },
            {
                "item": "viz_top_ports",
                "type": "block",
                "position": {"x": 540, "y": 280, "w": 520, "h": 380}
            },
            {
                "item": "viz_map",
                "type": "block",
                "position": {"x": 1080, "y": 280, "w": 500, "h": 380}
            },
            {
                "item": "viz_recent_exposures",
                "type": "block",
                "position": {"x": 20, "y": 680, "w": 1560, "h": 400}
            }
        ],
        "globalInputs": [
            "input_global_trp"
        ]
    }
}
